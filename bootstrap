#!/usr/bin/env bash
#
# Bootstrap a fresh Linux server from local machine.
# Installs your SSH public key on the new user, then kicks off the full setup.
#
# Usage (run locally):
#   bash bootstrap <user> <email> <host> [hostname]
#
# One-liner (downloads to temp file first — required to avoid stdin conflict with curl pipe):
#   curl -fsSL https://raw.githubusercontent.com/yangou/setup/main/bootstrap -o /tmp/bootstrap
#   bash /tmp/bootstrap <user> <email> <host> [hostname]

set -euo pipefail

SETUP_REPO="https://github.com/yangou/setup.git"

if [[ $# -lt 3 ]]; then
  echo "Usage: bootstrap <user> <email> <host> [hostname]"
  exit 1
fi

USERNAME="$1"
EMAIL="$2"
HOST="$3"
HOSTNAME_ARG="${4:-}"

# ── Find local SSH public key ─────────────────────────────────────────────────
PUB_KEY=""
for f in ~/.ssh/id_ed25519.pub ~/.ssh/id_rsa.pub ~/.ssh/id_ecdsa.pub; do
  if [[ -f "$f" ]]; then
    PUB_KEY="$(cat "$f")"
    echo "==> Using SSH public key: $f"
    break
  fi
done

if [[ -z "$PUB_KEY" ]]; then
  echo "ERROR: No SSH public key found in ~/.ssh/. Run: ssh-keygen -t ed25519"
  exit 1
fi

# ── Prompt for root password (used only for the initial connection) ───────────
echo -n "Root password for root@$HOST: "
read -rs ROOT_PASS
echo

# Verify sshpass is available
if ! command -v sshpass &>/dev/null; then
  echo "ERROR: sshpass is required. Install with: brew install sshpass"
  exit 1
fi

SSH_OPTS="-o StrictHostKeyChecking=no -o PasswordAuthentication=yes -o PubkeyAuthentication=no"

# ── Step 1: SSH as root (password) to create user and install pub key ─────────
echo "==> Connecting as root@$HOST to create user '$USERNAME'..."
sshpass -p "$ROOT_PASS" ssh $SSH_OPTS root@"$HOST" \
  USERNAME="$USERNAME" PUB_KEY="$PUB_KEY" \
  'bash -s' <<'REMOTE'
set -euo pipefail

if ! id "$USERNAME" &>/dev/null; then
  useradd -m -s /bin/bash "$USERNAME"
  echo "==> Created user $USERNAME"
fi

mkdir -p "/home/$USERNAME/.ssh"
chmod 700 "/home/$USERNAME/.ssh"

# Install the caller's public key (idempotent)
if ! grep -qF "$PUB_KEY" "/home/$USERNAME/.ssh/authorized_keys" 2>/dev/null; then
  echo "$PUB_KEY" >> "/home/$USERNAME/.ssh/authorized_keys"
  echo "==> SSH public key added to $USERNAME"
fi
chmod 600 "/home/$USERNAME/.ssh/authorized_keys"
chown -R "$USERNAME:$USERNAME" "/home/$USERNAME/.ssh"

# Grant passwordless sudo
usermod -aG sudo "$USERNAME"
echo "$USERNAME ALL=(ALL) NOPASSWD:ALL" > "/etc/sudoers.d/$USERNAME"
chmod 440 "/etc/sudoers.d/$USERNAME"
echo "==> $USERNAME granted passwordless sudo"
REMOTE

# ── Step 2: SSH as user (key auth — no password) to clone setup and run install
echo "==> Connecting as $USERNAME@$HOST to run setup..."
ssh -o StrictHostKeyChecking=no "$USERNAME@$HOST" \
  SETUP_REPO="$SETUP_REPO" USERNAME="$USERNAME" EMAIL="$EMAIL" HOSTNAME_ARG="$HOSTNAME_ARG" \
  'bash -s' <<'REMOTE'
set -euo pipefail

mkdir -p ~/Workspace
if ! [ -d ~/Workspace/setup ]; then
  git clone "$SETUP_REPO" ~/Workspace/setup
else
  git -C ~/Workspace/setup pull
fi
git -C ~/Workspace/setup submodule update --init --recursive

~/Workspace/setup/install "$USERNAME" "$EMAIL" ${HOSTNAME_ARG:+"$HOSTNAME_ARG"}
REMOTE

echo "==> Bootstrap complete! SSH in with: ssh $USERNAME@$HOST"
