#!/usr/bin/env bash
#
# Cross-platform development environment bootstrap.
# Supports: macOS (desktop & headless), Ubuntu/Debian (server & desktop).
#
# Usage: ./install <user> <email>

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/lib/platform.sh"

if [[ $# -ne 2 ]]; then
  echo "Usage: ./install <user> <email>"
  exit 1
fi

USERNAME="$1"
EMAIL="$2"
OS="$(detect_os)"
GUI=$(has_gui && echo "yes" || echo "no")

log_info "Platform: $OS | GUI: $GUI"

if [[ "$OS" == "unsupported" ]]; then
  log_error "Unsupported operating system: $(uname -s)"
  exit 1
fi

# ── Linux root bootstrap: create user, then re-exec as that user ─────────────
# When a fresh server is accessed as root, create the target user first,
# copy root's SSH key and password, then hand off to that user.
if is_linux && [[ "$(id -u)" -eq 0 ]] && [[ "$USERNAME" != "root" ]]; then
  log_info "Running as root — setting up user '$USERNAME'..."

  if ! id "$USERNAME" &>/dev/null; then
    useradd -m -s /bin/bash "$USERNAME"
    log_info "Created user $USERNAME"
  fi

  # Copy root's authorized_keys so the user can SSH in with the same key
  if [[ -f /root/.ssh/authorized_keys ]]; then
    mkdir -p "/home/$USERNAME/.ssh"
    cp /root/.ssh/authorized_keys "/home/$USERNAME/.ssh/authorized_keys"
    chown -R "$USERNAME:$USERNAME" "/home/$USERNAME/.ssh"
    chmod 700 "/home/$USERNAME/.ssh"
    chmod 600 "/home/$USERNAME/.ssh/authorized_keys"
    log_info "SSH authorized_keys copied to $USERNAME"
  fi

  # Copy root's password hash so the user can use the same password.
  # Cloud providers often lock root's password (! or *) and use SSH keys only —
  # in that case fall back to prompting for a password.
  root_pass="$(getent shadow root | cut -d: -f2)"
  if [[ -n "$root_pass" && "$root_pass" != "!" && "$root_pass" != "*" && "$root_pass" != "!!" ]]; then
    usermod -p "$root_pass" "$USERNAME"
    log_info "Root password copied to $USERNAME"
  else
    log_info "Root has no password set — please set a password for $USERNAME:"
    passwd "$USERNAME"
  fi

  # Ensure SSH allows password authentication so the user can log in with a password
  if grep -qE '^\s*PasswordAuthentication\s+no' /etc/ssh/sshd_config 2>/dev/null; then
    sed_inplace 's/^\s*PasswordAuthentication\s\+no/PasswordAuthentication yes/' /etc/ssh/sshd_config
    log_info "Enabled PasswordAuthentication in sshd_config"
  elif ! grep -qE '^\s*PasswordAuthentication' /etc/ssh/sshd_config 2>/dev/null; then
    echo "PasswordAuthentication yes" >> /etc/ssh/sshd_config
    log_info "Added PasswordAuthentication yes to sshd_config"
  fi
  # Also check sshd_config.d drop-ins (Ubuntu 24.04 uses this)
  dropin="/etc/ssh/sshd_config.d/60-cloudimg-settings.conf"
  if [[ -f "$dropin" ]] && grep -qE '^\s*PasswordAuthentication\s+no' "$dropin"; then
    sed_inplace 's/^\s*PasswordAuthentication\s\+no/PasswordAuthentication yes/' "$dropin"
    log_info "Enabled PasswordAuthentication in $dropin"
  fi
  systemctl reload ssh 2>/dev/null || systemctl reload sshd 2>/dev/null || true

  # Grant passwordless sudo access (required for non-interactive installs)
  usermod -aG sudo "$USERNAME"
  echo "$USERNAME ALL=(ALL) NOPASSWD:ALL" > "/etc/sudoers.d/$USERNAME"
  chmod 440 "/etc/sudoers.d/$USERNAME"
  log_info "$USERNAME added to sudo group (NOPASSWD)"

  # Copy setup repo into user's home if it's currently in root's home
  TARGET_DIR="/home/$USERNAME/Workspace/setup"
  if [[ "$SCRIPT_DIR" != "$TARGET_DIR" ]]; then
    mkdir -p "/home/$USERNAME/Workspace"
    cp -r "$SCRIPT_DIR" "$TARGET_DIR"
    chown -R "$USERNAME:$USERNAME" "/home/$USERNAME/Workspace"
  fi

  log_info "Switching to $USERNAME — re-running install..."
  exec su -l "$USERNAME" -c "bash '$TARGET_DIR/install' '$USERNAME' '$EMAIL'"
fi

# ── SSH ─────────────────────────────────────────────────────────────────────
if ! [ -f ~/.ssh/id_rsa ]; then
  log_info "Generating SSH key..."
  mkdir -p ~/.ssh && chmod 700 ~/.ssh
  ssh-keygen -t rsa -b 4096 -C "$EMAIL" -N "" -f ~/.ssh/id_rsa
fi

# ── Platform-specific packages ──────────────────────────────────────────────
if is_macos; then
  source "$SCRIPT_DIR/lib/macos.sh"
  install_macos_prerequisites
  install_macos_packages "$SCRIPT_DIR" "$GUI"
elif is_linux; then
  source "$SCRIPT_DIR/lib/linux.sh"
  install_linux_all "$GUI"
fi

# ── asdf plugins & runtimes ─────────────────────────────────────────────────
# (asdf is installed via Homebrew on macOS, via git clone on Linux)
log_info "Setting up asdf plugins..."

# Ensure asdf is on PATH
if is_macos && command -v brew &>/dev/null; then
  source "$(brew --prefix asdf 2>/dev/null)/libexec/asdf.sh" 2>/dev/null || true
elif [[ -f "$HOME/.asdf/asdf.sh" ]]; then
  export PATH="$HOME/.asdf/bin:$PATH"
  source "$HOME/.asdf/asdf.sh"
fi

if command -v asdf &>/dev/null; then
  asdf plugin add golang  2>/dev/null || asdf plugin update golang
  asdf plugin add java    2>/dev/null || asdf plugin update java
  asdf plugin add erlang  2>/dev/null || asdf plugin update erlang
  asdf plugin add elixir  2>/dev/null || asdf plugin update elixir
  asdf plugin add ruby    2>/dev/null || asdf plugin update ruby
  asdf plugin add python  2>/dev/null || asdf plugin update python
  asdf plugin add rebar   2>/dev/null || asdf plugin update rebar
  asdf plugin add nodejs  2>/dev/null || asdf plugin update nodejs
  asdf plugin add rust    2>/dev/null || asdf plugin update rust

  # asdf 0.16+ uses `asdf set -u`; older bash versions use `asdf global`
  asdf_global() {
    asdf set -u "$1" "$2" 2>/dev/null || asdf global "$1" "$2"
  }

  log_info "Installing default runtimes..."
  asdf install nodejs 22.22.1
  asdf_global nodejs 22.22.1
  npm config set prefix ~/.npm-global

  asdf install golang 1.23.4
  asdf_global golang 1.23.4

  asdf install java openjdk-23.0.1
  asdf_global java openjdk-23.0.1

  # Enable gobin helper
  if [[ -f ~/.asdf/plugins/golang/set-env.zsh ]]; then
    cat "$SCRIPT_DIR/golang/set-env.zsh" > ~/.asdf/plugins/golang/set-env.zsh
  fi
else
  log_warn "asdf not found; skipping runtime installation"
fi

# ── Oh My Zsh ───────────────────────────────────────────────────────────────
log_info "Setting up Oh My Zsh..."
if ! [ -d ~/.oh-my-zsh ]; then
  sh -c "$(curl -fsSL https://raw.githubusercontent.com/ohmyzsh/ohmyzsh/master/tools/install.sh | sed 's/exec zsh -l//g')"
else
  git -C ~/.oh-my-zsh pull
fi

# ── Powerlevel10k ───────────────────────────────────────────────────────────
log_info "Setting up Powerlevel10k..."
if ! [ -d ~/powerlevel10k ]; then
  git clone --depth=1 https://github.com/romkatv/powerlevel10k.git ~/powerlevel10k
  git clone --depth=1 https://github.com/powerline/fonts.git ~/powerlevel10k/fonts
  # Only install fonts if there's a GUI to display them
  if [[ "$GUI" == "yes" ]]; then
    ~/powerlevel10k/fonts/install.sh
  fi
else
  git -C ~/powerlevel10k pull
fi

# ── Vim (maximum-awesome) ──────────────────────────────────────────────────
log_info "Setting up Vim..."
if ! [ -d ~/maximum-awesome ]; then
  git clone https://github.com/yangou/maximum-awesome.git ~/maximum-awesome
fi
cd ~/maximum-awesome
git pull
sed_inplace 's/File\.exists?/File.exist?/g' Rakefile 2>/dev/null || true
if is_macos && command -v rake &>/dev/null; then
  # rake sets up symlinks and installs deps via brew — macOS only
  rake 2>/dev/null || log_warn "rake failed - you may need to run it manually"
elif is_linux; then
  # On Linux, rake calls brew and aborts — create symlinks manually instead
  ln -sf ~/maximum-awesome/vimrc          ~/.vimrc
  ln -sf ~/maximum-awesome/vimrc.bundles  ~/.vimrc.bundles
  mkdir -p ~/.vim
  if ! [ -d ~/.vim/bundle/Vundle.vim ]; then
    git clone https://github.com/VundleVim/Vundle.vim.git ~/.vim/bundle/Vundle.vim
  fi
fi
cd "$SCRIPT_DIR"

ensure_line "source $SCRIPT_DIR/vim/.vimrc.bundles.local" ~/.vimrc.bundles.local
ensure_line "source $SCRIPT_DIR/vim/.vimrc.local" ~/.vimrc.local

vim -es -u ~/.vimrc +PluginInstall +qall 2>/dev/null || true
vim -es -u ~/.vimrc +GoInstallBinaries +qall 2>/dev/null || true

if [ -d ~/.vim/bundle/coc.nvim ]; then
  cd ~/.vim/bundle/coc.nvim
  # Ensure npm is available via asdf shims
  export PATH="$HOME/.asdf/shims:$HOME/.asdf/bin:$PATH"
  npm ci 2>/dev/null || true
  npm run build 2>/dev/null || true
  npm audit fix 2>/dev/null || true
  cd "$SCRIPT_DIR"
fi

# ── Neovim ──────────────────────────────────────────────────────────────────
log_info "Setting up Neovim..."
mkdir -p ~/.config
if ! [ -e ~/.config/nvim ]; then
  ln -s "$SCRIPT_DIR/nvim" ~/.config/nvim
fi

nvim --headless -c "Lazy! install" -c "qa" 2>/dev/null || true
nvim --headless -c "GoInstallBinaries" -c "qa" 2>/dev/null || true

if [ -d ~/.local/share/nvim/lazy/coc.nvim ]; then
  cd ~/.local/share/nvim/lazy/coc.nvim
  export PATH="$HOME/.asdf/shims:$HOME/.asdf/bin:$PATH"
  npm ci 2>/dev/null || true
  npm run build 2>/dev/null || true
  npm audit fix 2>/dev/null || true
  cd "$SCRIPT_DIR"
fi

# ── Claude Code plugins ────────────────────────────────────────────────────
if command -v claude &>/dev/null; then
  log_info "Setting up Claude Code plugins..."
  claude plugin marketplace add affaan-m/everything-claude-code
  claude plugin marketplace add obra/superpowers-marketplace
  claude plugin marketplace add jarrodwatts/claude-hud
  claude plugin marketplace add anthropics/claude-code
  claude plugin marketplace add anthropics/claude-plugins-official
  claude plugin marketplace add mixedbread-ai/mgrep

  claude plugin install everything-claude-code@everything-claude-code
  claude plugin install superpowers@superpowers-marketplace
  claude plugin install claude-hud@claude-hud
else
  log_warn "claude not found; skipping Claude Code plugin setup"
fi

# ── Everything Claude Code rules ────────────────────────────────────────────
mkdir -p ~/Workspace
if ! [ -d ~/Workspace/everything-claude-code ]; then
  git clone https://github.com/affaan-m/everything-claude-code.git ~/Workspace/everything-claude-code
else
  git -C ~/Workspace/everything-claude-code pull
fi
if [ -f ~/Workspace/everything-claude-code/install.sh ]; then
  cd ~/Workspace/everything-claude-code
  npm install 2>/dev/null || true
  ./install.sh typescript golang python swift php
  cd "$SCRIPT_DIR"
fi

# ── Tmux ────────────────────────────────────────────────────────────────────
log_info "Setting up Tmux..."
if ! [ -d ~/.tmux/plugins/tpm ]; then
  git clone https://github.com/tmux-plugins/tpm ~/.tmux/plugins/tpm
else
  git -C ~/.tmux/plugins/tpm pull
fi
ensure_line "source $SCRIPT_DIR/tmux/.tmux.conf.local" ~/.tmux.conf.local

# ── Git ─────────────────────────────────────────────────────────────────────
log_info "Configuring Git..."
git config --global alias.co checkout
git config --global alias.br branch
git config --global alias.cp cherry-pick
git config --global alias.cm commit
git config --global alias.df diff
git config --global alias.st status
git config --global user.name "$USERNAME"
git config --global user.email "$EMAIL"

# ── Shell config ────────────────────────────────────────────────────────────
log_info "Configuring shell..."
ensure_line "source $SCRIPT_DIR/zsh/.zprofile" ~/.zprofile
ensure_line "source $SCRIPT_DIR/zsh/.zshrc" ~/.zshrc

# Set zsh as default shell if it isn't already
if [[ "$(basename "$SHELL")" != "zsh" ]]; then
  log_info "Setting zsh as default shell..."
  local_zsh="$(which zsh)"
  if is_linux; then
    _sudo chsh -s "$local_zsh" "$USER"
  else
    chsh -s "$local_zsh"
  fi
fi

log_info "Setup complete! Restart your shell or run: exec zsh -l"
